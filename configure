"${R_HOME}/bin/Rscript" -e 'mkvars <- "./src/Makevars"; mk_lines <- readLines(mkvars); mk_lines[grepl("^PKG_CPPFLAGS", mk_lines)] <- paste(mk_lines[grepl("^PKG_CPPFLAGS", mk_lines)], "-D_REENTRANT"); writeLines(mk_lines, mkvars)'
